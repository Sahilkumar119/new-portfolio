{
  "github": {
    "silent": true
  },
  "buildCommand": "npm run build",
  "outputDirectory": "build",
  "cleanUrls": true,
  "redirects": [
    {
      "source": "/learn/sql/modules/:slug/:file",
      "destination": "/learn/sql/:slug",
      "permanent": true
    },
    {
      "source": "/learn/sql/modules/:slug",
      "destination": "/learn/sql/:slug",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/((?!learn/[^/]).*)",
      "destination": "/index.html"
    }
  ]
}
